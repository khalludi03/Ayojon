{
  "name": "my-better-t-app",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "better-auth": "^1.4.9"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:native": "bun run --filter native dev",
    "dev:web": "bun run --filter web dev",
    "dev:server": "bun run --filter server dev",
    "db:push": "bun run --filter @my-better-t-app/db db:push",
    "db:studio": "bun run --filter @my-better-t-app/db db:studio",
    "db:generate": "bun run --filter @my-better-t-app/db db:generate",
    "db:migrate": "bun run --filter @my-better-t-app/db db:migrate",
    "db:seed": "bun run packages/db/src/seed.ts",
    "db:seed:production": "bun run packages/db/src/seed-production.ts",
    "check:emails": "bun scripts/check-email-mismatch.ts",
    "fix:emails": "bun scripts/fix-email-accounts.ts",
    "verify:db": "bun scripts/verify-db-state.ts",
    "check:user": "bun scripts/check-user-accounts.ts",
    "list:users": "bun scripts/list-all-users.ts",
    "prepare": "husky",
    "lint": "NODE_OPTIONS='--max-old-space-size=8192' eslint apps packages scripts --max-warnings=0",
    "lint:fix": "NODE_OPTIONS='--max-old-space-size=8192' eslint apps packages scripts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@faker-js/faker": "^10.2.0",
    "@base-ui/react": "^1.0.0",
    "@logtail/browser": "^0.5.6",
    "@radix-ui/react-avatar": "^1.1.11",
    "@sentry/react": "^10.38.0",
    "@tanstack/react-form": "^1.23.5",
    "@tanstack/react-query": "^5.80.6",
    "@tanstack/react-router": "^1.141.1",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.141.1",
    "@tanstack/router-plugin": "^1.141.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.525.0",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.2.5",
    "@my-better-t-app/env": "workspace:*",
    "@my-better-t-app/storage": "workspace:*",
    "@orpc/client": "^1.13.4",
    "@orpc/openapi": "^1.13.4",
    "@orpc/server": "^1.13.4",
    "@orpc/tanstack-query": "^1.13.4",
    "@orpc/zod": "^1.13.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "dotenv": "catalog:",
    "framer-motion": "^12.29.2",
    "nodemailer": "^7.0.13",
    "orpc": "^0.1.1",
    "supabase": "^2.72.9",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@my-better-t-app/config": "workspace:*",
    "@tanstack/eslint-config": "^0.3.4",
    "@types/bun": "catalog:",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "drizzle-orm": "^0.45.1",
    "eslint": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "pg": "^8.18.0",
    "prettier": "^3.8.1",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.6",
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
